generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/nutricoach_app/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}


model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String   @map("password_hash")
  name              String?
  languagePreference String  @default("en") @map("language_preference")
  referralSource    String?  @map("referral_source") // utm_source from shared link
  referralSlug      String?  @map("referral_slug") // slug of shared plan that referred user
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  profile           Profile?
  mealPlans         MealPlan[]
  trackingEntries   TrackingEntry[]
  chatSessions      ChatSession[]
  challengeInstances ChallengeInstance[]
  challengeStats    ChallengeStats[]
  leaderboardEvents LeaderboardEvent[]
  userStreak        UserStreak?
  streakEvents      StreakEvent[]
  subscription      Subscription?
  
  // Social relationships
  sentFriendRequests     Friendship[]   @relation("FriendshipUser")
  receivedFriendRequests Friendship[]   @relation("FriendshipFriend")
  ownedGroups            Group[]        @relation("GroupOwner")
  groupMemberships       GroupMember[]
  groupChallengesCreated GroupChallenge[] @relation("GroupChallengeCreator")
  groupChallengeParticipations GroupChallengeParticipant[]
  activityFeed           ActivityFeed[]
  activityReactions      ActivityReaction[]
  notifications          Notification[]

  @@map("users")
}

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  age           Int
  sex           String   // 'male' or 'female'
  weightKg      Float    @map("weight_kg")
  heightCm      Float    @map("height_cm")
  activityLevel String   @map("activity_level") // sedentary, light, moderate, active, very_active
  goal          String   // maintain, lose_weight, gain_weight, improve_health
  medicalFlags  Json     @default("[]") @map("medical_flags") // JSONB array of flags
  dietaryPrefs  Json     @default("[]") @map("dietary_prefs") // vegetarian, vegan, etc.
  // Public identity fields for leaderboard
  displayName   String?  @map("display_name")
  avatarSeed    String?  @map("avatar_seed") // For deterministic avatar generation
  publicOptIn   Boolean  @default(false) @map("public_opt_in")
  country       String?
  timezone      String?
  // Social privacy settings
  socialEnabled       Boolean @default(true) @map("social_enabled") // Master switch for social features
  showActivityToFriends Boolean @default(true) @map("show_activity_to_friends")
  allowFriendRequests Boolean @default(true) @map("allow_friend_requests")
  showOnLeaderboard   Boolean @default(true) @map("show_on_leaderboard")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calculations  Calculation[]

  @@map("profiles")
}

model Calculation {
  id              String   @id @default(uuid())
  profileId       String   @map("profile_id")
  formulaVersion  String   @map("formula_version") // e.g., "harris-benedict-v1"
  geb             Float    // Gasto Energético Basal
  eta             Float    // Efecto Térmico de los Alimentos
  get             Float    // Gasto Energético Total
  bmr             Float    // Same as GEB (English alias)
  tdee            Float    // Same as GET (English alias)
  carbG           Float    @map("carb_g")
  proteinG        Float    @map("protein_g")
  fatG            Float    @map("fat_g")
  fiberTargetG    Float    @map("fiber_target_g")
  carbPercent     Float    @default(60) @map("carb_percent")
  proteinPercent  Float    @default(12) @map("protein_percent")
  fatPercent      Float    @default(28) @map("fat_percent")
  createdAt       DateTime @default(now()) @map("created_at")

  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mealPlans       MealPlan[]

  @@index([profileId])
  @@map("calculations")
}

model NutritionRule {
  id         String   @id @default(uuid())
  ruleType   String   @map("rule_type") // geb_formula, eta_formula, activity_factor, macro_distribution
  parameters Json     // JSONB with rule parameters
  version    String
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("nutrition_rules")
}

model FoodItem {
  id           String   @id @default(uuid())
  name         String   // English name
  nameEs       String   @map("name_es") // Spanish name
  regionTags   Json     @default("[]") @map("region_tags") // ["usa", "mexico", "latam"]
  category     String   // proteins, carbs, fats, vegetables, fruits, dairy, legumes, grains
  servingSize  Float    @map("serving_size")
  servingUnit  String   @map("serving_unit") // g, ml, piece, cup, tbsp
  kcal         Float
  carbG        Float    @map("carb_g")
  proteinG     Float    @map("protein_g")
  fatG         Float    @map("fat_g")
  fiberG       Float    @map("fiber_g")
  createdAt    DateTime @default(now()) @map("created_at")

  equivalentsFrom EquivalentsCatalog[] @relation("FromFood")
  equivalentsTo   EquivalentsCatalog[] @relation("ToFood")
  mealItems       MealItem[]
  trackingEntries TrackingEntry[]

  @@index([category])
  @@index([name])
  @@map("food_items")
}

model EquivalentsCatalog {
  id               String   @id @default(uuid())
  foodId           String   @map("food_id")
  equivalentFoodId String   @map("equivalent_food_id")
  ratio            Float    // How much of equivalent equals 1 serving of original

  food             FoodItem @relation("FromFood", fields: [foodId], references: [id], onDelete: Cascade)
  equivalentFood   FoodItem @relation("ToFood", fields: [equivalentFoodId], references: [id], onDelete: Cascade)

  @@unique([foodId, equivalentFoodId])
  @@map("equivalents_catalog")
}

model MealPlan {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  calculationId String   @map("calculation_id")
  startDate     DateTime @map("start_date")
  days          Json     // JSONB with 7 days of meals
  shoppingList  Json     @default("[]") @map("shopping_list")
  preferences   Json     @default("{}") // dietary preferences used
  createdAt     DateTime @default(now()) @map("created_at")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  calculation   Calculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  meals         Meal[]
  sharedPlans   SharedPlan[]

  @@index([userId])
  @@map("meal_plans")
}

model SharedPlan {
  id         String    @id @default(uuid())
  planId     String    @map("plan_id")
  slug       String    @unique // short unique string for URL
  isPublic   Boolean   @default(true) @map("is_public")
  expiresAt  DateTime? @map("expires_at")
  viewCount  Int       @default(0) @map("view_count")
  createdAt  DateTime  @default(now()) @map("created_at")

  mealPlan   MealPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@map("shared_plans")
}

model Meal {
  id           String   @id @default(uuid())
  mealPlanId   String   @map("meal_plan_id")
  dayNumber    Int      @map("day_number") // 1-7
  mealType     String   @map("meal_type") // breakfast, lunch, dinner, snack_am, snack_pm
  name         String
  nameEs       String   @map("name_es")
  totalKcal    Float    @map("total_kcal")
  totalCarbG   Float    @map("total_carb_g")
  totalProteinG Float   @map("total_protein_g")
  totalFatG    Float    @map("total_fat_g")

  mealPlan     MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  items        MealItem[]

  @@index([mealPlanId])
  @@map("meals")
}

model MealItem {
  id       String @id @default(uuid())
  mealId   String @map("meal_id")
  foodId   String @map("food_id")
  quantity Float
  unit     String

  meal     Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food     FoodItem @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@map("meal_items")
}

model TrackingEntry {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  mealType  String   @map("meal_type")
  foodId    String   @map("food_id")
  quantity  Float
  unit      String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  food      FoodItem @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("tracking_entries")
}

model ChatSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  role      String   // user, assistant, system
  content   String   @db.Text
  citations Json?    // Optional citations from RAG
  createdAt DateTime @default(now()) @map("created_at")

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

model PdfChunk {
  id           String   @id @default(uuid())
  chunkId      String   @unique @map("chunk_id")
  sectionTitle String   @map("section_title")
  pageNumber   Int      @map("page_number")
  text         String   @db.Text
  embedding    String?  @db.Text // Store as JSON string if vector not available
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([sectionTitle])
  @@map("pdf_chunks")
}

// ============== CHALLENGE MODE TABLES ==============

model ChallengeTemplate {
  id            String   @id @default(uuid())
  name          String   @unique
  nameEs        String   @map("name_es")
  description   String   @db.Text
  descriptionEs String   @map("description_es") @db.Text
  durationDays  Int      @map("duration_days")
  macroRules    Json     @map("macro_rules") // { proteinMinPercent: 30, proteinBonus: true, etc. }
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  instances       ChallengeInstance[]
  stats           ChallengeStats[]
  groupChallenges GroupChallenge[]

  @@map("challenge_templates")
}

model ChallengeInstance {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  templateId   String   @map("template_id")
  planId       String?  @map("plan_id") // Associated meal plan
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  status       String   @default("active") // active, completed, abandoned
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template     ChallengeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  progress     ChallengeProgress[]
  shares       ChallengeShare[]
  leaderboardEvents LeaderboardEvent[]

  @@index([userId])
  @@index([templateId])
  @@index([status])
  @@map("challenge_instances")
}

model ChallengeProgress {
  id                  String    @id @default(uuid())
  challengeInstanceId String    @map("challenge_instance_id")
  dayNumber           Int       @map("day_number") // 1-7
  completed           Boolean   @default(false)
  completedAt         DateTime? @map("completed_at")
  proteinConsumed     Float?    @map("protein_consumed") // grams
  notes               String?   @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")

  challengeInstance   ChallengeInstance @relation(fields: [challengeInstanceId], references: [id], onDelete: Cascade)

  @@unique([challengeInstanceId, dayNumber])
  @@index([challengeInstanceId])
  @@map("challenge_progress")
}

model ChallengeShare {
  id                  String   @id @default(uuid())
  challengeInstanceId String   @map("challenge_instance_id")
  slug                String   @unique
  viewCount           Int      @default(0) @map("view_count")
  createdAt           DateTime @default(now()) @map("created_at")

  challengeInstance   ChallengeInstance @relation(fields: [challengeInstanceId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@map("challenge_shares")
}

model ChallengeStats {
  id                      String    @id @default(uuid())
  userId                  String    @map("user_id")
  templateId              String    @map("template_id")
  totalDaysCompleted      Int       @default(0) @map("total_days_completed")
  currentStreakDays       Int       @default(0) @map("current_streak_days")
  bestStreakDays          Int       @default(0) @map("best_streak_days")
  challengeCompletedCount Int       @default(0) @map("challenge_completed_count")
  lastCompletedAt         DateTime? @map("last_completed_at")
  pointsTotal             Int       @default(0) @map("points_total")
  pointsWeekly            Int       @default(0) @map("points_weekly")
  weeklyResetAt           DateTime? @map("weekly_reset_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template  ChallengeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([pointsTotal])
  @@index([pointsWeekly])
  @@map("challenge_stats")
}

model LeaderboardEvent {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  challengeInstanceId String?   @map("challenge_instance_id")
  eventType           String    @map("event_type") // DAY_COMPLETED, CHALLENGE_COMPLETED, SHARE_CREATED, STREAK_BONUS
  pointsAwarded       Int       @map("points_awarded")
  metadata            Json?     // Additional event data
  createdAt           DateTime  @default(now()) @map("created_at")

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeInstance   ChallengeInstance? @relation(fields: [challengeInstanceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("leaderboard_events")
}

// ============== STREAK SYSTEM TABLES ==============

model UserStreak {
  id                    String    @id @default(uuid())
  userId                String    @unique @map("user_id")
  currentStreak         Int       @default(0) @map("current_streak")
  bestStreak            Int       @default(0) @map("best_streak")
  lastActivityDate      DateTime? @map("last_activity_date") @db.Date
  streakFreezesAvailable Int      @default(2) @map("streak_freezes_available")
  freezesResetAt        DateTime? @map("freezes_reset_at") // Reset monthly
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentStreak])
  @@index([bestStreak])
  @@map("user_streaks")
}

model StreakEvent {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  eventType     String   @map("event_type") // DAY_COMPLETED, AI_INTERACTION, PLAN_VIEW, STREAK_FREEZE_USED, STREAK_BROKEN
  streakBefore  Int      @map("streak_before")
  streakAfter   Int      @map("streak_after")
  metadata      Json?    // Additional event data like milestone reached
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("streak_events")
}

// ============== SOCIAL ACCOUNTABILITY SYSTEM ==============

model Friendship {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  status    String   @default("pending") // pending, accepted, blocked
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@index([status])
  @@map("friendships")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  ownerId     String   @map("owner_id")
  avatarSeed  String?  @map("avatar_seed")
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner       User            @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  challenges  GroupChallenge[]

  @@index([ownerId])
  @@map("groups")
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  role     String   @default("member") // admin, member
  joinedAt DateTime @default(now()) @map("joined_at")

  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model GroupChallenge {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  templateId  String   @map("template_id")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  createdBy   String   @map("created_by")
  status      String   @default("active") // active, completed
  createdAt   DateTime @default(now()) @map("created_at")

  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  template    ChallengeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  creator     User              @relation("GroupChallengeCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  participants GroupChallengeParticipant[]

  @@index([groupId])
  @@index([templateId])
  @@index([status])
  @@map("group_challenges")
}

model GroupChallengeParticipant {
  id                String   @id @default(uuid())
  groupChallengeId  String   @map("group_challenge_id")
  userId            String   @map("user_id")
  progressDays      Int      @default(0) @map("progress_days")
  streak            Int      @default(0)
  points            Int      @default(0)
  joinedAt          DateTime @default(now()) @map("joined_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  groupChallenge    GroupChallenge @relation(fields: [groupChallengeId], references: [id], onDelete: Cascade)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupChallengeId, userId])
  @@index([groupChallengeId])
  @@index([userId])
  @@index([points])
  @@map("group_challenge_participants")
}

model ActivityFeed {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  eventType   String   @map("event_type") // CHALLENGE_STARTED, DAY_COMPLETED, STREAK_MILESTONE, CHALLENGE_COMPLETED
  referenceId String?  @map("reference_id") // ID of related entity
  metadata    Json?    // Additional event data
  createdAt   DateTime @default(now()) @map("created_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions   ActivityReaction[]

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("activity_feed")
}

model ActivityReaction {
  id           String   @id @default(uuid())
  activityId   String   @map("activity_id")
  userId       String   @map("user_id")
  reactionType String   @map("reaction_type") // fire, muscle, clap
  createdAt    DateTime @default(now()) @map("created_at")

  activity     ActivityFeed @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([activityId])
  @@index([userId])
  @@map("activity_reactions")
}

model Notification {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  type         String    // FRIEND_REQUEST, FRIEND_COMPLETED_DAY, REACTION_RECEIVED, LEADERBOARD_PASSED
  title        String
  message      String
  referenceId  String?   @map("reference_id")
  isRead       Boolean   @default(false) @map("is_read")
  createdAt    DateTime  @default(now()) @map("created_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============== GROWTH LOOP ANALYTICS ==============

model GrowthEvent {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id") // Nullable for anonymous events
  sessionId   String?  @map("session_id") // For tracking anonymous sessions
  eventType   String   @map("event_type") // PLAN_GENERATED, CHALLENGE_STARTED, DAY_COMPLETED, CHALLENGE_COMPLETED, SHARE_CREATED, SHARE_CLICKED, USER_REGISTERED
  sourceSlug  String?  @map("source_slug") // Referral source (challenge/plan share slug)
  metadata    Json?    // Additional event data
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([eventType])
  @@index([sourceSlug])
  @@index([createdAt])
  @@map("growth_events")
}

// Temporary storage for guest onboarding flow (before account creation)
model OnboardingSession {
  id             String    @id @default(uuid())
  goal           String    // lose_weight, build_muscle, eat_healthier, maintain_weight
  age            Int?
  sex            String?   // male, female
  heightCm       Float?    @map("height_cm")
  weightKg       Float?    @map("weight_kg")
  activityLevel  String?   @map("activity_level") // sedentary, light, moderate, active, very_active
  
  // Calculated results
  dailyCalories  Float?    @map("daily_calories")
  carbG          Float?    @map("carb_g")
  proteinG       Float?    @map("protein_g")
  fatG           Float?    @map("fat_g")
  mealPreview    Json?     @map("meal_preview") // Sample meal plan preview
  
  // Session management
  currentStep    Int       @default(1) @map("current_step")
  completedAt    DateTime? @map("completed_at")
  convertedToUserId String? @map("converted_to_user_id") // User ID if converted
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@index([convertedToUserId])
  @@map("onboarding_sessions")
}

// ============== MONETIZATION / SUBSCRIPTIONS ==============

model Subscription {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  planType      String    @default("free") @map("plan_type") // free, pro
  status        String    @default("active") // active, trialing, past_due, canceled, expired
  billingCycle  String?   @map("billing_cycle") // monthly, yearly (null for free)
  trialStart    DateTime? @map("trial_start")
  trialEnd      DateTime? @map("trial_end")
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  canceledAt    DateTime? @map("canceled_at")
  stripeCustomerId    String? @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([planType])
  @@map("subscriptions")
}

model SubscriptionEvent {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  eventType     String   @map("event_type") // trial_started, trial_converted, subscription_started, subscription_canceled, upgrade_prompt_shown, upgrade_prompt_clicked
  planType      String?  @map("plan_type")
  billingCycle  String?  @map("billing_cycle")
  source        String?  // Where the event occurred (e.g., "meal_plan", "ai_coach", "analytics")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("subscription_events")
}

// ============== REFERRAL SYSTEM ==============

model Referral {
  id             String    @id @default(uuid())
  referralCode   String    @unique @map("referral_code") // Unique code for sharing
  referrerUserId String    @map("referrer_user_id")
  referredUserId String?   @unique @map("referred_user_id") // Null until conversion
  status         String    @default("pending") // pending, converted, expired
  convertedAt    DateTime? @map("converted_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([referralCode])
  @@index([referrerUserId])
  @@index([status])
  @@map("referrals")
}

model UserReferralStats {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  referralCode       String   @unique @map("referral_code") // User's unique referral code
  totalReferrals     Int      @default(0) @map("total_referrals")
  convertedReferrals Int      @default(0) @map("converted_referrals")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_referral_stats")
}

// ============== ACQUISITION ANALYTICS ==============

model AcquisitionEvent {
  id              String   @id @default(uuid())
  userId          String?  @map("user_id") // Null for anonymous visitors
  sessionId       String?  @map("session_id") // Browser session tracking
  source          String   // seo, social, referral, direct, product_hunt
  landingPage     String?  @map("landing_page") // Which page they landed on
  referralCode    String?  @map("referral_code") // If from referral
  utmSource       String?  @map("utm_source")
  utmMedium       String?  @map("utm_medium")
  utmCampaign     String?  @map("utm_campaign")
  converted       Boolean  @default(false) // Did they sign up?
  convertedAt     DateTime? @map("converted_at")
  metadata        Json?    // Additional tracking data
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([source])
  @@index([userId])
  @@index([converted])
  @@index([createdAt])
  @@map("acquisition_events")
}

// ============== SEO CALCULATOR RESULTS ==============

model CalculatorResult {
  id             String   @id @default(uuid())
  sessionId      String?  @map("session_id") // For anonymous users
  userId         String?  @map("user_id") // For logged in users
  calculatorType String   @map("calculator_type") // macro, calorie, protein, meal_plan
  inputs         Json     // Calculator inputs
  results        Json     // Calculator results
  convertedToSignup Boolean @default(false) @map("converted_to_signup")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([calculatorType])
  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
  @@map("calculator_results")
}